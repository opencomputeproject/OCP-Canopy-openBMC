+					phy0: ethernet-phy@0 {
+						compatible = "ethernet-phy-ieee802.3-c22";
+						reg = <0>;
+					};
+				};
+			};
+
+			umac1: ethernet@5000 {
+				compatible = "hpe,gxp-umac";
+				reg = <0x5000 0x100>;
+				phy-mode = "gmii";
+				phy-handle = <&phy1>;
+				nvmem-cells = <&mac_address1>;
+				nvmem-cell-names = "mac-address";
+				status = "okay";
+
+				mdio1: mdio {
+					compatible = "hpe,gxp-umac-mdio";
+					#address-cells = <1>;
+					#size-cells = <0>;
+
