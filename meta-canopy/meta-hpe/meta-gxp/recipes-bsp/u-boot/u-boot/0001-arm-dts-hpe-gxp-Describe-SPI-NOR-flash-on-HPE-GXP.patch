From 3eb0a2c434e8c84bc73bb0fe19708f8d939bf6b8 Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Wed, 21 Jan 2026 17:59:29 +0100
Subject: [PATCH] arm: dts: hpe-gxp: Describe SPI NOR flash on HPE GXP

Add flash@0 child node to the SPI controller. The SPI-NOR framework
requires this child node to probe the flash device. Use generic
"jedec,spi-nor" compatible for auto-detection based on the flash's
built-in JEDEC ID.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 arch/arm/dts/hpe-gxp-u-boot.dtsi | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/arch/arm/dts/hpe-gxp-u-boot.dtsi b/arch/arm/dts/hpe-gxp-u-boot.dtsi
index 63a1a11fed2..7e9d9a171a4 100644
--- a/arch/arm/dts/hpe-gxp-u-boot.dtsi
+++ b/arch/arm/dts/hpe-gxp-u-boot.dtsi
@@ -19,6 +19,11 @@
 				#address-cells = <1>;
 				#size-cells = <0>;
 				status = "okay";
+
+				flash@0 {
+					compatible = "jedec,spi-nor";
+					reg = <0>;
+				};
 			};
 		};
 	};
-- 
2.52.0

