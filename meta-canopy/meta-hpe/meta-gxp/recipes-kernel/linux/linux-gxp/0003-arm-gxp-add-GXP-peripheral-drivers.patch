+	schedule_work(&c->work);
+	spin_unlock_irqrestore(&c->lock, flags);
+
+	return 0;
+}
+*/
+
+
+static ssize_t gxp_spi_write(struct gxp_spi_chip *chip, const struct spi_mem_op *op)
+{
+	struct gxp_spi *spifi = chip->spifi;
+	void __iomem *reg_base = spifi->reg_base;
+	u32 write_len;
+	u32 value;
+	int ret;
+
+	write_len = op->data.nbytes;
+	if (write_len > SPILDAT_LEN)
+		write_len = SPILDAT_LEN;
+
+	value = readl(reg_base + OFFSET_SPIMCFG);
+	value &= ~(1 << 24);
+	value |= (chip->cs << 24);
+	value &= ~(0x07 << 16);
+	value |= (op->addr.nbytes << 16);
+	value &= ~(0x1f << 19);
+	writel(value, reg_base + OFFSET_SPIMCFG);
+
+	writel(op->addr.val, reg_base + OFFSET_SPIADDR);
+
+	writeb(op->cmd.opcode, reg_base + OFFSET_SPICMD);
+
+	writew(write_len, reg_base + OFFSET_SPIDCNT);
+
+	memcpy_toio(spifi->dat_base, op->data.buf.in, write_len);
+
+	value = readb(reg_base + OFFSET_SPIMCTRL);
+	value |= SPIMCTRL_DIR;
+	value |= SPIMCTRL_START;
+
+	writeb(value, reg_base + OFFSET_SPIMCTRL);
+
+	ret = readb_poll_timeout(reg_base + OFFSET_SPIMCTRL, value,
+				 !(value & SPIMCTRL_BUSY),
+				 GXP_SPI_SLEEP_TIME, GXP_SPI_TIMEOUT);
+	if (ret) {
+		dev_warn(spifi->dev, "write busy time out\n");
+		return ret;
+	}
+
+	return 0;
+}
+
+static int do_gxp_exec_mem_op(struct spi_mem *mem, const struct spi_mem_op *op)
+{
+	struct gxp_spi *spifi = spi_controller_get_devdata(mem->spi->controller);
+	// vejmarie
+	// struct gxp_spi_chip *chip = &spifi->chips[spi_get_chipselect(mem->spi, 0)];
+	struct gxp_spi_chip *chip = &spifi->chips[mem->spi->chip_select];
+	int ret = 0;
+//      pr_info("gxp-spi: Mem op\n");
+
+	if (op->data.dir == SPI_MEM_DATA_IN) {
+		if (!op->addr.nbytes)
+			ret = gxp_spi_read_reg(chip, op);
+		else
+			// vejmarie gxp_spi_read
+			ret = gxp_spi_read_reg(chip, op);
+	} else {
+		if (!op->addr.nbytes)
+			ret = gxp_spi_write_reg(chip, op);
+		else
+			// vejmarie gxp_spi_write
+			ret = gxp_spi_write_reg(chip, op);
+	}
+
+	return ret;
+}
+
+static int gxp_exec_mem_op(struct spi_mem *mem, const struct spi_mem_op *op)
+{
+	int ret;
+
+//      pr_info("gxp-spi: exec mem op\n");
+	ret = do_gxp_exec_mem_op(mem, op);
+	if (ret)
+		dev_err(&mem->spi->dev, "operation failed: %d", ret);
+
+	return ret;
+}
+
+static const struct spi_controller_mem_ops gxp_spi_mem_ops = {
+	.exec_op = gxp_exec_mem_op,
+};
+
+static int gxp_spi_setup(struct spi_device *spi)
+{
+
+	struct gxp_spi *spifi = spi_controller_get_devdata(spi->controller);
+	// vejmarie
+	// unsigned int cs = spi_get_chipselect(spi, 0);
+	unsigned int cs = spi->chip_select;
+	struct gxp_spi_chip *chip = &spifi->chips[cs];
+//      pr_info("gxp-spi: running setup\n");
+
+	chip->spifi = spifi;
+	chip->cs = cs;
+	pr_info("spi-gxp: set manual mode\n");
+	gxp_spi_set_mode(spifi, MANUAL_MODE);
+
+	return 0;
+}
+
+static int gxp_spi_transfer(struct spi_controller *ctlr,
+				   struct spi_message *msg)
+{
+	struct spi_transfer *xfer = NULL;
+	struct spi_transfer *xfer_rx = NULL;
+	struct spi_transfer *xfer_tx = NULL;
+	struct gxp_spi *spifi = spi_controller_get_devdata(ctlr);
+	struct spi_device *spidev = msg->spi;
+	u8 *buf = NULL;
+	u32 tx_len = 0;
+	u32 rx_len = 0;
+	u32 i;
+	u32 ret;
+	u32 addr;
+	unsigned int value = 0;
+	int msg_t = 0;
+	int transfer_cnt = 0;
+
+	// GXP ASIC doesn't support raw transfer mode
+	// They have to be merged either in
+	// Write/Read transfer and faked with CMD + ADDR + DATA
+	// Write only
+	// Anything else can't work as we do not have fine grain control
+	// of the SPI interface which was designed for SPI-NOR
+	// For W5500 that shouldn't be a massive issue as
+	// - Reads are processed through a write-read operation
+	// (the write is providing the address to the device and the control byte)
+	// - Write are raw write without any feedback from the device
+
+
+	list_for_each_entry(xfer, &msg->transfers,
+			    transfer_list) {
+		transfer_cnt++;
+		pr_info("gxp-spi: looping\n");
+		if (xfer->tx_buf) {
+			pr_info("gxp-spi: transmit buffer\n");
+			msg_t = msg_t | 1;
+		}
+		if ((xfer->rx_buf)) {
+			msg_t = msg_t | 2;
+			pr_info("gxp-spi: read buffer set\n");
+		}
+	}
+	pr_info("gxp-spi: Message type %d cnt %d\n", msg_t, transfer_cnt);
+//      pr_info("gxp-spi: Running transfer\n");
+
+	if (transfer_cnt > 2) {
+		// not supported
+		return EINVAL;
+	}
+	// So we need at least 2 messages, and one read
+	// otherwise we process only the write operations
+	// if we have multiple write/read that will be tricky
+	if ((transfer_cnt == 2) && (msg_t == 3)) {
+		xfer_tx = list_first_entry_or_null(&msg->transfers, struct spi_transfer, transfer_list);
+		if (xfer_tx->tx_buf) {
+			pr_info("First message is a Transmit\n");
+		}
+		xfer_rx = list_next_entry(xfer_tx, transfer_list);
+		if (xfer_rx->rx_buf) {
+			pr_info("Second message is a read of %d bytes\n", xfer_rx->len);
+		}
+			 buf = (u8 *)xfer_tx->tx_buf;
+		 pr_info("gxp-spi: transfer receiving mode\n");
+		 // let's setup the read operation
+		 // 2 bytes addressing + 1 byte CMD
+		 value = readl(spifi->reg_base + OFFSET_SPIMCFG);
+		 value &= ~(1 << 24);
+		 value |= (0 << 24);
+		 value &= ~(0x07 << 16);
+		 value |= (2 << 16);
+		 value &= ~(0x1f << 19);
+		 // override
+		 value = 0x20007;
+		 writel(value, spifi->reg_base + OFFSET_SPIMCFG);
+		 // write the command
+		 pr_info("Data transmitted : %x %x %x\n", buf[0], buf[1], buf[2]);
+		 writeb(buf[0], spifi->reg_base + OFFSET_SPICMD);
+		 // write the address (0x19 into our trial)
+		 // make it a writel !!!
+		 addr = 0;
+		 addr |= buf[1] << 8;
+		 addr |= buf[2];
+		 writel(addr, spifi->reg_base + OFFSET_SPIADDR);
+//                 writeb(buf[1], spifi->reg_base + OFFSET_SPIADDR);
+//                 writeb(buf[2], spifi->reg_base + OFFSET_SPIADDR+1);
+		pr_info("spi-gxp: spi frame %x%x\n", buf[0], addr);
+
+		 pr_info("spi-gxp: Configuration register %lx\n", value);
+		 // writel(0, spifi->reg_base + OFFSET_SPIADDR);
+		 writew(xfer_rx->len, spifi->reg_base + OFFSET_SPIDCNT);
+		 value = readb(spifi->reg_base + OFFSET_SPIMCTRL);
+		 value &= ~SPIMCTRL_DIR;
+		 value |= SPIMCTRL_START;
+		 pr_info("gxp-spi: MCTRL %x\n", value);
+		 writeb(value, spifi->reg_base + OFFSET_SPIMCTRL);
+		 ret = readb_poll_timeout(spifi->reg_base + OFFSET_SPIMCTRL, value,
+			 !(value & SPIMCTRL_BUSY),
+			 GXP_SPI_SLEEP_TIME, GXP_SPI_TIMEOUT);
+		if (ret) {
+			  dev_warn(spifi->dev, "read reg busy time out\n");
+			return ret;
+		}
+		  memcpy_fromio((u8 *)xfer_rx->rx_buf, spifi->dat_base, xfer_rx->len);
+		  buf = (u8 *)xfer_rx->rx_buf;
+		  for (i = 0 ; i < xfer_rx->len ; i++) {
+			 pr_info("gxp-spi: %x\n", *buf++);
+		}
+		goto done;
+
+
+	}
+	list_for_each_entry(xfer, &msg->transfers,
+			    transfer_list) {
+		if ((xfer->tx_buf) && (xfer->rx_buf)) {
+			pr_info("We got a write/read operation\n");
+		} else if (xfer->tx_buf) {
+			buf = (u8 *)xfer->tx_buf;
+			// tx_len = xfer->len - 1;
+			tx_len = xfer->len;
+			pr_info("gxp-spi: transfer buffer filled with %d bytes\n", xfer->len);
+			for (i = 0; i < tx_len; i++) {
+				pr_info("gxp-spi: Data %x\n", buf[i]);
+			}
+			// Ok we can try to write the data
+			// memcpy((u8 *)spifi->reg_base + OFFSET_SPILDAT, buf, tx_len);
+			// we shall do one byte into the command register
+			// 3 bytes addressing
+			// remaining is data
+			value = readl(spifi->reg_base + OFFSET_SPIMCFG);
+									value &= ~(1 << 24);
+			value |= (0 << 24);
+			value &= ~(0x07 << 16);
+			value |= (3 << 16);
+			value &= ~(0x1f << 19);
+			pr_info("gxp-spi: Write operation MCFG %x\n", value);
+			writel(value, spifi->reg_base + OFFSET_SPIMCFG);
+			// write the command
+			writeb(buf[0], spifi->reg_base + OFFSET_SPICMD);
+			// write the address
+			addr = 0;
+			addr |= buf[1] << 16;
+			addr |= buf[2] << 8;
+			addr |= buf[3];
+			writel(addr, spifi->reg_base + OFFSET_SPIADDR);
+//                      writeb(buf[1], spifi->reg_base + OFFSET_SPIADDR);
+//                      writeb(buf[2], spifi->reg_base + OFFSET_SPIADDR+1);
+//                      writeb(buf[3], spifi->reg_base + OFFSET_SPIADDR+2);
+			// remaining bytes
+			if ((tx_len-4) > 0) {
+				writew(tx_len-4, spifi->reg_base + OFFSET_SPIDCNT);
+				memcpy_toio((u8 *)spifi->dat_base, &buf[4], tx_len-4);
+			} else {
+				writew(0, spifi->reg_base + OFFSET_SPIDCNT);
+			}
+			//
+			value = readb(spifi->reg_base + OFFSET_SPIMCTRL);
+			value |= (1<<3);
+			writeb(value, spifi->reg_base + OFFSET_SPIMCTRL);
+			writeb(tx_len, spifi->reg_base + OFFSET_SPIDCNT);
+			// set the start bit to run the transfer
+									value = readb(spifi->reg_base + OFFSET_SPIMCTRL);
+																value |= SPIMCTRL_START;
+																writeb(value, spifi->reg_base + OFFSET_SPIMCTRL);
+
+																//wait busy bit is cleared
+																do {
+																								value = readb(spifi->reg_base + OFFSET_SPIMCTRL);
+																} while (value & SPIMCTRL_BUSY);
+		}
+		/*      if (xfer->rx_buf) {
+			pr_info("gxp-spi: transfer receiving mode\n");
+			// let's setup the read operation
+			// 2 bytes addressing + 1 byte CMD
+			value = readl(spifi->reg_base + OFFSET_SPIMCFG);
+			value &= ~(1 << 24);
+			value |= (0 << 24);
+			value &= ~(0x07 << 16);
+			value |= (2 << 16);
+			value &= ~(0x1f << 19);
+			writel(value, spifi->reg_base + OFFSET_SPIMCFG);
+
+			pr_info("spi-gxp: Configuration register %lx\n", value);
+			writel(0, spifi->reg_base + OFFSET_SPIADDR);
+			writew(xfer->len, spifi->reg_base + OFFSET_SPIDCNT);
+			value = readb(spifi->reg_base + OFFSET_SPIMCTRL);
+			value &= ~SPIMCTRL_DIR;
+			value |= SPIMCTRL_START;
+			writeb(value, spifi->reg_base + OFFSET_SPIMCTRL);
+			ret = readb_poll_timeout(spifi->reg_base + OFFSET_SPIMCTRL, value,
+				 !(value & SPIMCTRL_BUSY),
+				 GXP_SPI_SLEEP_TIME, GXP_SPI_TIMEOUT);
+			if (ret) {
+				dev_warn(spifi->dev, "read reg busy time out\n");
+				return ret;
+									}
+			memcpy_fromio((u8 *)xfer->rx_buf, spifi->dat_base, xfer->len);
+			buf=(u8 *)xfer->rx_buf;
+			for(i=0 ; i < xfer->len ; i++) {
+				pr_info("gxp-spi: %x\n", *buf++);
+			}
+		}
+		*/
+	}
+
+done:
+	/* Update statistics */
+	msg->actual_length = tx_len + rx_len + 1;
+//      pr_info("gxp-spi: Data transfer: %d\n", msg->actual_length);
+	/* complete the transaction */
+	msg->status = 0;
+	spi_finalize_current_message(ctlr);
+//      pr_info("gxp-spi: exiting transfer\n");
+	return 0;
+}
+
+static int gxp_spifi_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	const struct gxp_spi_data *data;
+	struct spi_controller *ctlr;
+	struct gxp_spi *spifi;
+	int ret;
+	u32 max_clk_rate;
+	// For the moment we support only 1 node, while their could be 2 of them
+	struct device_node *np = dev->of_node;
+
+	data = of_device_get_match_data(&pdev->dev);
+
+	if (of_property_read_u32(np, "spi-max-frequency", &max_clk_rate)) {
+		dev_err(&pdev->dev, "couldn't determine spi-max-frequency of device node\n");
+		return -ENXIO;
+	}
+	pr_info("spi-gxp: Max clock rate set to %d\n", max_clk_rate);
+
+	// vejmarie
+	// ctlr = devm_spi_alloc_host(dev, sizeof(*spifi));
+//      pr_info("gxp-spi probe\n");
+	ctlr = devm_spi_alloc_master(dev, sizeof(*spifi));
+	if (!ctlr)
+		return -ENOMEM;
+
+	spifi = spi_controller_get_devdata(ctlr);
+	spifi->max_clk = max_clk_rate;
+	platform_set_drvdata(pdev, spifi);
+	spifi->data = data;
+	spifi->dev = dev;
+
+	spifi->reg_base = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(spifi->reg_base))
+		return PTR_ERR(spifi->reg_base);
+
+	spifi->dat_base = devm_platform_ioremap_resource(pdev, 1);
+	if (IS_ERR(spifi->dat_base))
+		return PTR_ERR(spifi->dat_base);
+
+	spifi->dir_base = devm_platform_ioremap_resource(pdev, 2);
+	if (IS_ERR(spifi->dir_base))
+		return PTR_ERR(spifi->dir_base);
+
+	ctlr->mode_bits = data->mode_bits;
+//      pr_info("spi-gxp: bus id %d\n", pdev->id);
+	// ctlr->bus_num = pdev->id;
+	ctlr->bus_num = 1;
+//      pr_info("spi-gxp: bus id %d\n",ctlr->bus_num);
+	ctlr->mem_ops = &gxp_spi_mem_ops;
+	ctlr->transfer_one_message = gxp_spi_transfer;
+	ctlr->setup = gxp_spi_setup;
+	ctlr->num_chipselect = data->max_cs;
+
+//      pr_info("spi-gxp: chipselect max %d\n", ctlr->num_chipselect);
+	ctlr->dev.of_node = dev->of_node;
+
+	ret = devm_spi_register_controller(dev, ctlr);
+	if (ret) {
+		return dev_err_probe(&pdev->dev, ret,
+				     "failed to register spi controller\n");
+	}
+
+	return 0;
+}
+
+static const struct gxp_spi_data gxp_spifi_data = {
+	.max_cs = 2,
+	.mode_bits = 0,
+};
+
+static const struct of_device_id gxp_spifi_match[] = {
+	{.compatible = "hpe,gxp2-spifi", .data = &gxp_spifi_data },
+	{ /* null */ }
+};
+
+MODULE_DEVICE_TABLE(of, gxp_spifi_match);
+
+static struct platform_driver gxp_spifi_driver = {
+	.probe = gxp_spifi_probe,
+	.driver = {
+		.name = "gxp2-spifi",
+		.of_match_table = gxp_spifi_match,
+	},
+};
+module_platform_driver(gxp_spifi_driver);
+
+MODULE_DESCRIPTION("HPE GXP SPI Flash Interface driver");
+MODULE_AUTHOR("Nick Hawkins <nick.hawkins@hpe.com>");
+MODULE_LICENSE("GPL");
