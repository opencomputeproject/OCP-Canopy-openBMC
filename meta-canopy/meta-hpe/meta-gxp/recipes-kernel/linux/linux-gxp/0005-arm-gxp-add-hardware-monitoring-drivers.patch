--- /dev/null
+++ b/drivers/hwmon/ubm-drv.c
@@ -0,0 +1,213 @@
+// SPDX-License-Identifier: GPL-2.0
+/* Copyright (C) 2023 Hewlett-Packard Development Company, L.P.
+ *
