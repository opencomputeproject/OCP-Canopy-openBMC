 static void gxp_restart(enum reboot_mode mode, const char *cmd)
 {
+	int i;
 	pr_info("gpx restart");
+	printk("Restarting GXP\n");
+//	__raw_writel(0x10084, (void __iomem *) IOP_REGS_VIRT_BASE + 0xc0);
+	__raw_writel(0x180FC, (void __iomem *) IOP_REGS_VIRT_BASE + 0xc0);
