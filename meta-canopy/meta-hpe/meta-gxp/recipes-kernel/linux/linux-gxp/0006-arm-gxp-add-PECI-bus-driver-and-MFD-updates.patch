 	priv->adapter = adapter;
@@ -190,6 +193,7 @@ static int gxp_peci_probe(struct platform_device *pdev)
 		ret = -ENODEV;
 		goto err_put_adapter_dev;
 	}
+	printk("gxp-peci: irq identified\n");
 
 	ret = devm_request_irq(&pdev->dev, priv->irq, gxp_peci_irq_handler,
 			       0, "peci-gxp-irq", priv);
@@ -205,6 +209,7 @@ static int gxp_peci_probe(struct platform_device *pdev)
 	priv->adapter->xfer = gxp_peci_xfer;
 	priv->adapter->use_dma = false;
 
+	printk("peci:adding adapter\n");
 	ret = peci_add_adapter(priv->adapter);
 	if (ret)
 		goto err_put_adapter_dev;
@@ -223,7 +228,7 @@ static int gxp_peci_probe(struct platform_device *pdev)
 static int gxp_peci_remove(struct platform_device *pdev)
 {
 	struct gxp_peci *priv = dev_get_drvdata(&pdev->dev);
-
+	printk("peci: removing driver\n");
 	peci_del_adapter(priv->adapter);
 	of_node_put(priv->adapter->dev.of_node);
 
