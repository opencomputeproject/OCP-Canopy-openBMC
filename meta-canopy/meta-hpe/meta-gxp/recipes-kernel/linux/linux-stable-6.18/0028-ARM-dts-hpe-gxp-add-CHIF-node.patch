From 3d3c8dbc196c7378c2fdf8c265ccbc2cc6bdbbe0 Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Tue, 3 Feb 2026 16:10:37 +0100
Subject: [PATCH] ARM: dts: hpe-gxp: add CHIF node

Add device tree node for the GXP Channel Interface (CHIF) used for
host-BMC communication via shared memory.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 arch/arm/boot/dts/hpe/hpe-gxp.dts | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/arch/arm/boot/dts/hpe/hpe-gxp.dts b/arch/arm/boot/dts/hpe/hpe-gxp.dts
index 210b6900512d..f591685921f1 100644
--- a/arch/arm/boot/dts/hpe/hpe-gxp.dts
+++ b/arch/arm/boot/dts/hpe/hpe-gxp.dts
@@ -197,6 +197,12 @@ fn2: fn2@80200000 {
 				"post-complete",
 				/* 4: Button state (input) */
 				"btn-state";
+
+			chif: chif {
+				compatible = "hpe,gxp-chif";
+				interrupts = <12>;
+				interrupt-parent = <&vic0>;
+			};
 		};
 
 		espi: espi@80fe0000 {
-- 
2.52.0

