From 9cbfadb5f50ebc0a21eac9d909433a4c4b279b91 Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Thu, 12 Feb 2026 09:16:58 +0100
Subject: [PATCH] regulator: gxp-cpld: add HPE GXP CPLD host power supply
 driver

Add a regulator driver that exposes the CPLD-controlled host power
state on HPE GXP BMC SoCs. The CPLD manages a power rail gating fans
and other host-dependent peripherals. this driver reads the power-good
status from the FN2 system event status register via regmap. Enable and
disable operations are no-ops since the CPLD controls the rail directly.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 drivers/regulator/Kconfig              | 11 ++++
 drivers/regulator/Makefile             |  1 +
 drivers/regulator/gxp-cpld-regulator.c | 77 ++++++++++++++++++++++++++
 3 files changed, 89 insertions(+)
 create mode 100644 drivers/regulator/gxp-cpld-regulator.c

diff --git a/drivers/regulator/Kconfig b/drivers/regulator/Kconfig
index d84f3d054c59..550cc85fead6 100644
--- a/drivers/regulator/Kconfig
+++ b/drivers/regulator/Kconfig
@@ -450,6 +450,17 @@ config REGULATOR_GPIO
 	  and the platform has to provide a mapping of GPIO-states
 	  to target volts/amps.
 
+config REGULATOR_GXP_CPLD
+	tristate "HPE GXP CPLD host power supply"
+	depends on (ARCH_HPE_GXP && MFD_SYSCON) || COMPILE_TEST
+	help
+	  This driver exposes the CPLD-controlled host power state on
+	  HPE GXP BMC SoCs as a regulator. The enable state is read
+	  from the FN2 system event status register (power-good bit).
+
+	  This driver can also be built as a module. If so, the module
+	  will be called gxp-cpld-regulator.
+
 config REGULATOR_HI6421
 	tristate "HiSilicon Hi6421 PMIC voltage regulator support"
 	depends on MFD_HI6421_PMIC && OF
diff --git a/drivers/regulator/Makefile b/drivers/regulator/Makefile
index b3101376029d..5721e03169ba 100644
--- a/drivers/regulator/Makefile
+++ b/drivers/regulator/Makefile
@@ -53,6 +53,7 @@ obj-$(CONFIG_REGULATOR_DB8500_PRCMU) += db8500-prcmu.o
 obj-$(CONFIG_REGULATOR_FAN53555) += fan53555.o
 obj-$(CONFIG_REGULATOR_FAN53880) += fan53880.o
 obj-$(CONFIG_REGULATOR_GPIO) += gpio-regulator.o
+obj-$(CONFIG_REGULATOR_GXP_CPLD) += gxp-cpld-regulator.o
 obj-$(CONFIG_REGULATOR_HI6421) += hi6421-regulator.o
 obj-$(CONFIG_REGULATOR_HI6421V530) += hi6421v530-regulator.o
 obj-$(CONFIG_REGULATOR_HI6421V600) += hi6421v600-regulator.o
diff --git a/drivers/regulator/gxp-cpld-regulator.c b/drivers/regulator/gxp-cpld-regulator.c
new file mode 100644
index 000000000000..ad2c977d1805
--- /dev/null
+++ b/drivers/regulator/gxp-cpld-regulator.c
@@ -0,0 +1,77 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * HPE GXP CPLD Host Power Supply
+ *
+ * Exposes the CPLD-controlled host power state as a regulator.
+ * The enable state is read from the FN2 system event status register
+ * (PGOOD bit). The power rail is controlled by the CPLD, not software.
+ *
+ * Copyright (C) 2026 9elements GmbH
+ */
+
+#include <linux/mfd/syscon.h>
+#include <linux/module.h>
+#include <linux/mod_devicetable.h>
+#include <linux/platform_device.h>
+#include <linux/regmap.h>
+#include <linux/regulator/driver.h>
+#include <linux/soc/hpe/gxp-regs.h>
+
+/* No-op: CPLD controls the power rail, not software */
+static int gxp_cpld_reg_noop(struct regulator_dev *rdev)
+{
+	return 0;
+}
+
+static const struct regulator_ops gxp_cpld_reg_ops = {
+	.is_enabled = regulator_is_enabled_regmap,
+	.enable     = gxp_cpld_reg_noop,
+	.disable    = gxp_cpld_reg_noop,
+};
+
+static const struct regulator_desc gxp_cpld_reg_desc = {
+	.name        = "gxp-host-power",
+	.type        = REGULATOR_VOLTAGE,
+	.ops         = &gxp_cpld_reg_ops,
+	.owner       = THIS_MODULE,
+	.enable_reg  = FN2_SEVSTAT,
+	.enable_mask = FN2_SEVSTAT_PGOOD_STATE,
+};
+
+static int gxp_cpld_reg_probe(struct platform_device *pdev)
+{
+	struct regulator_config config = {};
+	struct regulator_dev *rdev;
+	struct regmap *regmap;
+
+	regmap = syscon_node_to_regmap(pdev->dev.parent->of_node);
+	if (IS_ERR(regmap))
+		return dev_err_probe(&pdev->dev, PTR_ERR(regmap),
+				     "failed to get parent regmap\n");
+
+	config.dev = &pdev->dev;
+	config.of_node = pdev->dev.of_node;
+	config.regmap = regmap;
+
+	rdev = devm_regulator_register(&pdev->dev, &gxp_cpld_reg_desc,
+				       &config);
+	return PTR_ERR_OR_ZERO(rdev);
+}
+
+static const struct of_device_id gxp_cpld_reg_of_match[] = {
+	{ .compatible = "hpe,gxp-host-power-supply" },
+	{}
+};
+MODULE_DEVICE_TABLE(of, gxp_cpld_reg_of_match);
+
+static struct platform_driver gxp_cpld_reg_driver = {
+	.probe  = gxp_cpld_reg_probe,
+	.driver = {
+		.name = "gxp-cpld-regulator",
+		.of_match_table = gxp_cpld_reg_of_match,
+	},
+};
+module_platform_driver(gxp_cpld_reg_driver);
+
+MODULE_DESCRIPTION("HPE GXP CPLD Host Power Supply");
+MODULE_LICENSE("GPL");
-- 
2.52.0

