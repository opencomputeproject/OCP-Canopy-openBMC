 obj-$(CONFIG_SOC_HPE_GXP_XREG)		+= gxp-xreg.o
 obj-$(CONFIG_SOC_HPE_GXP_FN2)		+= gxp-fn2.o
 obj-$(CONFIG_SOC_HPE_GXP_POWER_CTRL)	+= gxp-power-ctrl.o
