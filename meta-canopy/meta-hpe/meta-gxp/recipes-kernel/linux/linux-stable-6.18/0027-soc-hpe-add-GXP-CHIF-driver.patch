index b3094d2460bd..6ebcc9678b09 100644
--- a/drivers/soc/hpe/Kconfig
+++ b/drivers/soc/hpe/Kconfig
@@ -74,4 +74,16 @@ config SOC_HPE_GXP_POWER_CTRL
 	  It exposes two GPIO lines (power-button and power-good)
 	  for integration with x86-power-control.
 
+config SOC_HPE_GXP_CHIF
+	tristate "HPE GXP CHIF support"
+	depends on ARCH_HPE_GXP || COMPILE_TEST
+	select SOC_HPE_GXP
+	select MFD_SYSCON
+	select REGMAP_MMIO
+	help
+	  Say Y here to add support for the HPE GXP CHIF (Channel
+	  Interface) block. This provides character device access
+	  (/dev/chif24) for bidirectional host-BMC communication
+	  via 1MB DMA-coherent shared memory.
+
 endif # SOC_HPE
