From 0e57c834d91309a0b4cb9e76087fa38109aec79a Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Thu, 12 Feb 2026 09:13:10 +0100
Subject: [PATCH] dt-bindings: regulator: add HPE GXP CPLD host power supply

Add YAML binding for the HPE GXP CPLD-controlled host power rail.
The CPLD manages a power rail gating fans and other host-dependent
devices; the regulator exposes the power-good state from the FN2
system event status register to consumer drivers.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 .../regulator/hpe,gxp-host-power-supply.yaml  | 44 +++++++++++++++++++
 1 file changed, 44 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/regulator/hpe,gxp-host-power-supply.yaml

diff --git a/Documentation/devicetree/bindings/regulator/hpe,gxp-host-power-supply.yaml b/Documentation/devicetree/bindings/regulator/hpe,gxp-host-power-supply.yaml
new file mode 100644
index 000000000000..685e54ffb3cc
--- /dev/null
+++ b/Documentation/devicetree/bindings/regulator/hpe,gxp-host-power-supply.yaml
@@ -0,0 +1,44 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/regulator/hpe,gxp-host-power-supply.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP CPLD Host Power Supply
+
+maintainers:
+  - Marcello Sylvester Bauer <marcello.bauer@9elements.com>
+
+description: |
+  The HPE GXP SoC uses a CPLD that controls the host power rail.
+  This regulator exposes the CPLD power-good state to consumer
+  devices (fans, sensors) through the regulator framework. The
+  enable state is read from the FN2 system event status register.
+
+  This node must be a child of the FN2 syscon node.
+
+allOf:
+  - $ref: regulator.yaml#
+
+properties:
+  compatible:
+    const: hpe,gxp-host-power-supply
+
+  regulator-name: true
+
+required:
+  - compatible
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    syscon@80200000 {
+      compatible = "hpe,gxp-fn2", "simple-mfd", "syscon";
+      reg = <0x80200000 0x100000>;
+
+      regulator-host-power {
+        compatible = "hpe,gxp-host-power-supply";
+        regulator-name = "host-power";
+      };
+    };
-- 
2.52.0

