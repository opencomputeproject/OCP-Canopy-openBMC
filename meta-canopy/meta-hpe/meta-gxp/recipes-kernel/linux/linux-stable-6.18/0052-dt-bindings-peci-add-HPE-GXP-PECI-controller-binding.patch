From 779b8deb0a4da7afa6774abaae7fc4d183fe9ca6 Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Thu, 12 Feb 2026 22:00:47 +0100
Subject: [PATCH] dt-bindings: peci: add HPE GXP PECI controller binding

Add device tree binding documentation for the HPE GXP PECI controller.
The GXP SoC includes a PECI bus controller for communicating with Intel
host processors for CPU and DIMM temperature monitoring.

An optional peci-supply property allows power gating the controller
when the host is off, avoiding PECI command timeouts.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 .../bindings/peci/hpe,gxp-peci.yaml           | 43 +++++++++++++++++++
 1 file changed, 43 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/peci/hpe,gxp-peci.yaml

diff --git a/Documentation/devicetree/bindings/peci/hpe,gxp-peci.yaml b/Documentation/devicetree/bindings/peci/hpe,gxp-peci.yaml
new file mode 100644
index 000000000000..258d0ccc65a1
--- /dev/null
+++ b/Documentation/devicetree/bindings/peci/hpe,gxp-peci.yaml
@@ -0,0 +1,43 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/peci/hpe,gxp-peci.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP PECI Bus
+
+maintainers:
+  - Marcello Sylvester Bauer <marcello.bauer@9elements.com>
+
+allOf:
+  - $ref: peci-controller.yaml#
+
+properties:
+  compatible:
+    const: hpe,gxp-peci
+
+  reg:
+    maxItems: 1
+
+  interrupts:
+    maxItems: 1
+
+  peci-supply:
+    description: Host power supply regulator for PECI bus power gating
+
+required:
+  - compatible
+  - reg
+  - interrupts
+
+additionalProperties: false
+
+examples:
+  - |
+    peci-controller@80000400 {
+      compatible = "hpe,gxp-peci";
+      reg = <0x80000400 0x200>;
+      interrupts = <22>;
+      interrupt-parent = <&vic1>;
+      peci-supply = <&host_power>;
+    };
-- 
2.52.0

