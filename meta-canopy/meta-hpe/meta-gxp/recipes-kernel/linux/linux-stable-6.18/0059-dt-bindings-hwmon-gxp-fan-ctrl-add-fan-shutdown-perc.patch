From 27b8e68d21745a7cc94afb01301c94c2ece3ad7f Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Fri, 13 Feb 2026 13:05:52 +0100
Subject: [PATCH] dt-bindings: hwmon: gxp-fan-ctrl: add fan-shutdown-percent
 property

Add an optional fan-shutdown-percent property (0-100) to configure the
PWM duty cycle applied to all present fans during kernel shutdown or
driver removal. This prevents fans from staying at a low duty cycle
set by userspace if the BMC reboots while the host is under load.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 .../devicetree/bindings/hwmon/hpe,gxp-fan-ctrl.yaml    | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/Documentation/devicetree/bindings/hwmon/hpe,gxp-fan-ctrl.yaml b/Documentation/devicetree/bindings/hwmon/hpe,gxp-fan-ctrl.yaml
index 3c3897639e29..1cb6405671ed 100644
--- a/Documentation/devicetree/bindings/hwmon/hpe,gxp-fan-ctrl.yaml
+++ b/Documentation/devicetree/bindings/hwmon/hpe,gxp-fan-ctrl.yaml
@@ -33,6 +33,15 @@ properties:
   fan-supply:
     description: Phandle to host power supply regulator for power gating
 
+  fan-shutdown-percent:
+    description:
+      PWM duty cycle percentage to set on all present fans during kernel
+      shutdown or driver removal. Prevents fans from running at a low
+      duty cycle set by userspace if the BMC reboots while the host is
+      under load. If unset, defaults to 50 percent.
+    minimum: 0
+    maximum: 100
+
 required:
   - compatible
   - reg
@@ -47,4 +56,5 @@ examples:
       reg = <0xc1000c00 0x200>;
       hpe,xreg = <&xreg>;
       fan-supply = <&host_power>;
+      fan-shutdown-percent = <50>;
     };
-- 
2.52.0

