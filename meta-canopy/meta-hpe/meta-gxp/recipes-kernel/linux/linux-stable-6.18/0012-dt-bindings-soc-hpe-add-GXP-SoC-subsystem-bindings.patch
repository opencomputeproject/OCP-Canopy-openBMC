From 620d807cfac9d350b84c1af0cc43b78c6e304c3a Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Sun, 8 Feb 2026 22:18:58 +0100
Subject: [PATCH] dt-bindings: soc: hpe: add GXP SoC subsystem bindings

Add YAML bindings for the HPE GXP CSM, XREG, and FN2 register
blocks that provide core BMC SoC infrastructure.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 .../bindings/soc/hpe/hpe,gxp-csm.yaml         | 39 ++++++++++
 .../bindings/soc/hpe/hpe,gxp-fn2.yaml         | 74 +++++++++++++++++++
 .../bindings/soc/hpe/hpe,gxp-xreg.yaml        | 67 +++++++++++++++++
 3 files changed, 180 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/soc/hpe/hpe,gxp-csm.yaml
 create mode 100644 Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml
 create mode 100644 Documentation/devicetree/bindings/soc/hpe/hpe,gxp-xreg.yaml

diff --git a/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-csm.yaml b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-csm.yaml
new file mode 100644
index 000000000000..736a920fcdc8
--- /dev/null
+++ b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-csm.yaml
@@ -0,0 +1,39 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/soc/hpe/hpe,gxp-csm.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP CSM (Slave Instrumentation and System Support)
+
+maintainers:
+  - Marcello Sylvester Bauer <marcello.bauer@9elements.com>
+
+description:
+  The HPE GXP SoC includes a CSM (Slave Instrumentation and System Support)
+  block that provides system control registers and GPIO functionality. This
+  driver exposes sysfs interfaces for controlling virtual EHCI enable and
+  software shutdown.
+
+properties:
+  compatible:
+    items:
+      - const: hpe,gxp-csm
+      - const: simple-mfd
+      - const: syscon
+
+  reg:
+    maxItems: 1
+
+required:
+  - compatible
+  - reg
+
+additionalProperties: false
+
+examples:
+  - |
+    csm: csm@80000000 {
+        compatible = "hpe,gxp-csm", "simple-mfd", "syscon";
+        reg = <0x80000000 0x400>;
+    };
diff --git a/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml
new file mode 100644
index 000000000000..35970054199d
--- /dev/null
+++ b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml
@@ -0,0 +1,74 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/soc/hpe/hpe,gxp-fn2.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP FN2 (Embedded Management Processor Support and Configuration)
+
+maintainers:
+  - Marcello Sylvester Bauer <marcello.bauer@9elements.com>
+
+description: |
+  The HPE GXP SoC includes a FN2 (Function 2) block that provides:
+  - GPIO lines for power state control (VPBTN, PGOOD, PERST)
+  - System event register for PGOOD/PERST interrupt handling
+  - Virtual power button control
+
+properties:
+  compatible:
+    items:
+      - const: hpe,gxp-fn2
+      - const: simple-mfd
+      - const: syscon
+
+  reg:
+    maxItems: 1
+    description: Memory region for FN2 registers
+
+  interrupts:
+    maxItems: 1
+    description: FN2 system event interrupt for PGOOD/PERST
+
+  interrupt-controller: true
+
+  "#interrupt-cells":
+    const: 2
+
+  gpio-controller: true
+
+  "#gpio-cells":
+    const: 2
+
+  gpio-line-names:
+    minItems: 1
+    maxItems: 50
+
+required:
+  - compatible
+  - reg
+  - interrupts
+  - gpio-controller
+  - "#gpio-cells"
+
+additionalProperties: false
+
+examples:
+  - |
+    fn2: fn2@80200000 {
+        compatible = "hpe,gxp-fn2", "simple-mfd", "syscon";
+        reg = <0x80200000 0x100000>;
+        interrupts = <0>;
+        interrupt-parent = <&vic1>;
+        interrupt-controller;
+        #interrupt-cells = <2>;
+        gpio-controller;
+        #gpio-cells = <2>;
+
+        gpio-line-names =
+            "vpbtn",        /* Virtual power button (output) */
+            "pgood",        /* Power good (input) */
+            "perst",        /* PCIe reset (input) */
+            "post-complete", /* POST complete (input) */
+            "btn-state";    /* Button state (input) */
+    };
diff --git a/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-xreg.yaml b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-xreg.yaml
new file mode 100644
index 000000000000..6393d7476040
--- /dev/null
+++ b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-xreg.yaml
@@ -0,0 +1,67 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/soc/hpe/hpe,gxp-xreg.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP XREG (Extended Register Block)
+
+maintainers:
+  - Marcello Sylvester Bauer <marcello.bauer@9elements.com>
+
+description: |
+  The HPE GXP SoC includes an extended register block (XREG) that provides:
+  - 150 GPIO lines for LEDs, fan status, PSU presence, and buttons
+  - Two interrupt groups (GRP5/GRP6) for edge-triggered events
+  - Server identification registers
+  - Sideband selection control
+
+properties:
+  compatible:
+    items:
+      - const: hpe,gxp-xreg
+      - const: simple-mfd
+      - const: syscon
+
+  reg:
+    maxItems: 1
+
+  interrupts:
+    maxItems: 1
+    description: XREG interrupt for GPIO events (GRP5/GRP6)
+
+  interrupt-controller: true
+
+  "#interrupt-cells":
+    const: 2
+
+  gpio-controller: true
+
+  "#gpio-cells":
+    const: 2
+
+  gpio-line-names:
+    minItems: 1
+    maxItems: 150
+
+required:
+  - compatible
+  - reg
+  - interrupts
+  - gpio-controller
+  - "#gpio-cells"
+
+additionalProperties: false
+
+examples:
+  - |
+    xreg: xreg@d1000000 {
+        compatible = "hpe,gxp-xreg", "simple-mfd", "syscon";
+        reg = <0xd1000000 0x11c>;
+        interrupts = <26>;
+        interrupt-parent = <&vic0>;
+        interrupt-controller;
+        #interrupt-cells = <2>;
+        gpio-controller;
+        #gpio-cells = <2>;
+    };
-- 
