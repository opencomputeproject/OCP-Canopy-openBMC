From 27608fa1aed3ecf9f7fd6d4ebb34f5842fa3aab7 Mon Sep 17 00:00:00 2001
From: Christian Walter <christian.walter@9elements.com>
Date: Tue, 17 Feb 2026 22:05:28 +0100
Subject: [PATCH] ARM: dts: hpe-gxp: rename PSU GPIO lines

Rename PSU GPIO lines from lowercase-hyphenated format to uppercase
convention expected by entity-manager:

  psu<N>-installed  ->  INST_PSU<N>
  psu<N>-ac-ok      ->  PSU<N>_AC
  psu<N>-dc-ok      ->  PSU<N>_DC

This naming convention matches the GPIO line names referenced in the
entity-manager PSU configuration for the HPE ProLiant Gen11 platform.

Signed-off-by: Nabla <nabla@9e.network>
---
 arch/arm/boot/dts/hpe/hpe-gxp.dts | 24 ++++++++++++------------
 1 file changed, 12 insertions(+), 12 deletions(-)

diff --git a/arch/arm/boot/dts/hpe/hpe-gxp.dts b/arch/arm/boot/dts/hpe/hpe-gxp.dts
index b7b49835dbd7..da251ea92480 100644
--- a/arch/arm/boot/dts/hpe/hpe-gxp.dts
+++ b/arch/arm/boot/dts/hpe/hpe-gxp.dts
@@ -159,24 +159,24 @@ xreg: xreg@d1000000 {
 				"", "", "", "", "", "", "", "",
 				"", "", "", "", "", "", "", "", "",
 				/* 90-97: PSU installed */
-				"psu1-installed", "psu2-installed",
-				"psu3-installed", "psu4-installed",
-				"psu5-installed", "psu6-installed",
-				"psu7-installed", "psu8-installed",
+				"INST_PSU1", "INST_PSU2",
+				"INST_PSU3", "INST_PSU4",
+				"INST_PSU5", "INST_PSU6",
+				"INST_PSU7", "INST_PSU8",
 				/* 98-99: Reserved */
 				"", "",
 				/* 100-107: PSU AC OK */
-				"psu1-ac-ok", "psu2-ac-ok",
-				"psu3-ac-ok", "psu4-ac-ok",
-				"psu5-ac-ok", "psu6-ac-ok",
-				"psu7-ac-ok", "psu8-ac-ok",
+				"PSU1_AC", "PSU2_AC",
+				"PSU3_AC", "PSU4_AC",
+				"PSU5_AC", "PSU6_AC",
+				"PSU7_AC", "PSU8_AC",
 				/* 108-109: Reserved */
 				"", "",
 				/* 110-117: PSU DC OK */
-				"psu1-dc-ok", "psu2-dc-ok",
-				"psu3-dc-ok", "psu4-dc-ok",
-				"psu5-dc-ok", "psu6-dc-ok",
-				"psu7-dc-ok", "psu8-dc-ok";
+				"PSU1_DC", "PSU2_DC",
+				"PSU3_DC", "PSU4_DC",
+				"PSU5_DC", "PSU6_DC",
+				"PSU7_DC", "PSU8_DC";
 
 			i2c_mux_ctrl: mux-controller {
 				compatible = "mmio-mux";
-- 
