From 2245b24dab778675e66b06fadea3cbb65f5320ff Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Tue, 3 Feb 2026 00:46:22 +0100
Subject: [PATCH] dt-bindings: soc: hpe: add GXP CHIF binding

Add device tree binding documentation for the HPE GXP Channel Interface
(CHIF) block. CHIF provides bidirectional communication between the BMC
and host CPU using DMA-coherent shared memory with doorbell interrupts.

The CHIF node must be a child of the FN2 syscon node.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 .../bindings/soc/hpe/hpe,gxp-chif.yaml        | 52 +++++++++++++++++++
 .../bindings/soc/hpe/hpe,gxp-fn2.yaml         |  4 ++
 2 files changed, 56 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/soc/hpe/hpe,gxp-chif.yaml

diff --git a/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-chif.yaml b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-chif.yaml
new file mode 100644
index 000000000000..30db5e79920e
--- /dev/null
+++ b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-chif.yaml
@@ -0,0 +1,52 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/soc/hpe/hpe,gxp-chif.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP CHIF (Channel Interface)
+
+maintainers:
+  - Marcello Sylvester Bauer <marcello.bauer@9elements.com>
+
+description: |
+  The HPE GXP SoC includes a Channel Interface (CHIF) block that provides
+  bidirectional communication between the BMC and host CPU. The driver
+  exposes a character device (/dev/chif24) for userspace applications to
+  exchange packets with the host.
+
+  Features:
+  - 1MB DMA-coherent shared memory with 32-channel CCB table
+  - Doorbell interrupt handling for packet notifications
+  - Read/write interface for packet exchange
+  - Sysfs interface for protocol header inspection
+
+  This node must be a child of the FN2 syscon node.
+
+properties:
+  compatible:
+    const: hpe,gxp-chif
+
+  interrupts:
+    maxItems: 1
+    description: Doorbell interrupt from host
+
+required:
+  - compatible
+  - interrupts
+
+additionalProperties: false
+
+examples:
+  - |
+    fn2: fn2@80200000 {
+        compatible = "hpe,gxp-fn2", "simple-mfd", "syscon";
+        reg = <0x80200000 0x100000>;
+        #address-cells = <1>;
+        #size-cells = <1>;
+
+        chif {
+            compatible = "hpe,gxp-chif";
+            interrupts = <12>;
+        };
+    };
diff --git a/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml
index 35970054199d..f7c79fa25681 100644
--- a/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml
+++ b/Documentation/devicetree/bindings/soc/hpe/hpe,gxp-fn2.yaml
@@ -44,6 +44,10 @@ properties:
     minItems: 1
     maxItems: 50
 
+  chif:
+    type: object
+    $ref: hpe,gxp-chif.yaml#
+
 required:
   - compatible
   - reg
-- 
2.52.0

