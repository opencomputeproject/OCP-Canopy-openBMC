From e98c3cbbdbdd3446c45da5537cb547253b19db4f Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Thu, 5 Feb 2026 10:06:30 +0100
Subject: [PATCH] ARM: dts: hpe-gxp: expand device tree for boot support

Add device tree nodes required for basic GXP BMC boot: watchdog, I2C
syscon and controllers, SPI flash controllers with partition maps,
and fan controller.

Restructure the bus hierarchy to use identity mapping. The previous
nested axi/ahb structure used offset-based address translation that
could not reach vic1 at 0x80f00000 from inside the 0xc0000000 bus
window. Identity mapping also allows device tree overlays to use
absolute physical addresses directly.

Extract the BMC flash partition definitions from hpe-gxp.dts into a
separate gxp-bmc-flash-layout.dtsi file, following the pattern used by
Aspeed. This allows OpenBMC/Yocto recipes to override the flash layout
without modifying the kernel base DTS.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 .../boot/dts/hpe/gxp-bmc-flash-layout.dtsi    |  58 ++++
 arch/arm/boot/dts/hpe/hpe-gxp.dts             | 299 ++++++++++++++----
 2 files changed, 291 insertions(+), 66 deletions(-)
 create mode 100644 arch/arm/boot/dts/hpe/gxp-bmc-flash-layout.dtsi

diff --git a/arch/arm/boot/dts/hpe/gxp-bmc-flash-layout.dtsi b/arch/arm/boot/dts/hpe/gxp-bmc-flash-layout.dtsi
new file mode 100644
index 000000000000..c8a4fe40a24a
--- /dev/null
+++ b/arch/arm/boot/dts/hpe/gxp-bmc-flash-layout.dtsi
@@ -0,0 +1,58 @@
+// SPDX-License-Identifier: GPL-2.0
+
+partitions {
+	compatible = "fixed-partitions";
+	#address-cells = <1>;
+	#size-cells = <1>;
+
+	bmc@0 {
+		reg = <0x0 0x1fc0000>;
+		label = "bmc";
+	};
+
+	u-boot@0 {
+		reg = <0x0 0x60000>;
+		label = "u-boot";
+	};
+
+	u-boot-env@70000 {
+		reg = <0x70000 0x20000>;
+		label = "u-boot-env";
+	};
+
+	kernel@80000 {
+		reg = <0x80000 0x4c0000>;
+		label = "kernel";
+	};
+
+	rofs@540000 {
+		reg = <0x540000 0x1a00000>;
+		label = "rofs";
+	};
+
+	rwfs@1f40000 {
+		reg = <0x1f40000 0x30000>;
+		label = "rwfs";
+	};
+
+	uboot-sig@1f70000 {
+		reg = <0x1f70000 0x10000>;
+		label = "uboot-sig";
+	};
+
+	gxp@1f80000 {
+		reg = <0x1f80000 0x80000>;
+		label = "gxp";
+	};
+
+	gxp-bootblock@1f80000 {
+		reg = <0x1f80000 0x40000>;
+		label = "gxp-bootblock";
+	};
+
+	gxp-ckb@1fc0000 {
+		reg = <0x1fc0000 0x40000>;
+		label = "gxp-ckb";
+		read-only;
+	};
+};
