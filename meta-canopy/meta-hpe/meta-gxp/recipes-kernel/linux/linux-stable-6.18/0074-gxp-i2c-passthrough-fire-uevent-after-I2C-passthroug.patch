From 33c290f836649950ddd89de57d899248c7290534 Mon Sep 17 00:00:00 2001
From: Pedro Maione <pedro.maione@9elements.com>
Date: Tue, 10 Mar 2026 10:55:52 -0300
Subject: [PATCH] gxp-i2c-passthrough: fire uevent after I2C passthrough enable

Fire a KOBJ_CHANGE uevent after bus_rescan_devices() completes so
udev can react to I2C devices becoming accessible behind the mux.

Signed-off-by: Pedro Maione <pedro.maione@9elements.com>
---
 drivers/soc/hpe/gxp-i2c-passthrough.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/soc/hpe/gxp-i2c-passthrough.c b/drivers/soc/hpe/gxp-i2c-passthrough.c
index b046ac45d6fc..d3b6fd4d7b15 100644
--- a/drivers/soc/hpe/gxp-i2c-passthrough.c
+++ b/drivers/soc/hpe/gxp-i2c-passthrough.c
@@ -12,6 +12,7 @@
  * Copyright (C) 2026 9elements GmbH
  */
 
+#include <linux/kobject.h>
 #include <linux/atomic.h>
 #include <linux/delay.h>
 #include <linux/device.h>
@@ -128,6 +129,7 @@ static void gxp_i2c_pt_enable_work_fn(struct work_struct *work)
 	atomic_set(&pt->enabled, 1);
 	regulator_notifier_call_chain(pt->rdev, REGULATOR_EVENT_ENABLE, NULL);
 	bus_rescan_devices(&i2c_bus_type);
+	kobject_uevent(&pt->dev->kobj, KOBJ_CHANGE);
 	dev_info(pt->dev, "I2C passthrough enabled\n");
 }
 
-- 
