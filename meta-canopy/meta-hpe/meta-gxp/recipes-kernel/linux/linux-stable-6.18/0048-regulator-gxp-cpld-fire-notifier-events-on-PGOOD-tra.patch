From 3adc308aa8d4f9bf0a2354d6637868cee1aa66de Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Fri, 13 Feb 2026 11:18:52 +0100
Subject: [PATCH] regulator: gxp-cpld: fire notifier events on PGOOD
 transitions

Add a threaded IRQ handler that fires REGULATOR_EVENT_ENABLE on
PGOOD assertion and REGULATOR_EVENT_DISABLE on PGOOD deassertion.
This allows consumer drivers to react to host power state changes
through the standard regulator notifier mechanism.

The interrupt is optional and specified via the DT interrupts
property. When absent, the driver behaves as before.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 drivers/regulator/gxp-cpld-regulator.c | 59 ++++++++++++++++++++++++--
 1 file changed, 55 insertions(+), 4 deletions(-)

diff --git a/drivers/regulator/gxp-cpld-regulator.c b/drivers/regulator/gxp-cpld-regulator.c
index ad2c977d1805..2bbf9555f871 100644
--- a/drivers/regulator/gxp-cpld-regulator.c
+++ b/drivers/regulator/gxp-cpld-regulator.c
@@ -6,9 +6,14 @@
  * The enable state is read from the FN2 system event status register
  * (PGOOD bit). The power rail is controlled by the CPLD, not software.
  *
+ * When a PGOOD interrupt is provided via device tree, the driver fires
+ * regulator notifier events on power transitions so that consumer
+ * drivers (e.g. PECI) can manage device lifecycle accordingly.
+ *
  * Copyright (C) 2026 9elements GmbH
  */
 
+#include <linux/interrupt.h>
 #include <linux/mfd/syscon.h>
 #include <linux/module.h>
 #include <linux/mod_devicetable.h>
@@ -17,6 +22,11 @@
 #include <linux/regulator/driver.h>
 #include <linux/soc/hpe/gxp-regs.h>
 
+struct gxp_cpld_reg_data {
+	struct regulator_dev *rdev;
+	struct regmap *regmap;
+};
+
 /* No-op: CPLD controls the power rail, not software */
 static int gxp_cpld_reg_noop(struct regulator_dev *rdev)
 {
@@ -38,24 +48,65 @@ static const struct regulator_desc gxp_cpld_reg_desc = {
 	.enable_mask = FN2_SEVSTAT_PGOOD_STATE,
 };
 
+static irqreturn_t gxp_cpld_reg_pgood_irq(int irq, void *data)
+{
+	struct gxp_cpld_reg_data *priv = data;
+	unsigned int val;
+	int ret;
+
+	ret = regmap_read(priv->regmap, FN2_SEVSTAT, &val);
+	if (ret)
+		return IRQ_NONE;
+
+	if (val & FN2_SEVSTAT_PGOOD_STATE)
+		regulator_notifier_call_chain(priv->rdev,
+					      REGULATOR_EVENT_ENABLE, NULL);
+	else
+		regulator_notifier_call_chain(priv->rdev,
+					      REGULATOR_EVENT_DISABLE, NULL);
+
+	return IRQ_HANDLED;
+}
+
 static int gxp_cpld_reg_probe(struct platform_device *pdev)
 {
+	struct gxp_cpld_reg_data *priv;
 	struct regulator_config config = {};
-	struct regulator_dev *rdev;
 	struct regmap *regmap;
+	int irq, ret;
+
+	priv = devm_kzalloc(&pdev->dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
 
 	regmap = syscon_node_to_regmap(pdev->dev.parent->of_node);
 	if (IS_ERR(regmap))
 		return dev_err_probe(&pdev->dev, PTR_ERR(regmap),
 				     "failed to get parent regmap\n");
 
+	priv->regmap = regmap;
+
 	config.dev = &pdev->dev;
 	config.of_node = pdev->dev.of_node;
 	config.regmap = regmap;
 
-	rdev = devm_regulator_register(&pdev->dev, &gxp_cpld_reg_desc,
-				       &config);
-	return PTR_ERR_OR_ZERO(rdev);
+	priv->rdev = devm_regulator_register(&pdev->dev, &gxp_cpld_reg_desc,
+					     &config);
+	if (IS_ERR(priv->rdev))
+		return PTR_ERR(priv->rdev);
+
+	irq = platform_get_irq_optional(pdev, 0);
+	if (irq > 0) {
+		ret = devm_request_threaded_irq(&pdev->dev, irq, NULL,
+						gxp_cpld_reg_pgood_irq,
+						IRQF_ONESHOT | IRQF_SHARED,
+						"gxp-cpld-regulator", priv);
+		if (ret)
+			return dev_err_probe(&pdev->dev, ret,
+					     "failed to request pgood irq\n");
+	}
+
+	return 0;
 }
 
 static const struct of_device_id gxp_cpld_reg_of_match[] = {
