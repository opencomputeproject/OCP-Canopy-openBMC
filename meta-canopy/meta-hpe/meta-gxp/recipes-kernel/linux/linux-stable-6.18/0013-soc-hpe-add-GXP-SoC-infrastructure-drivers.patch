 drivers/soc/hpe/gxp-soclib.h     |  14 +
 drivers/soc/hpe/gxp-xreg.c       | 746 +++++++++++++++++++++++++++++++
 include/linux/soc/hpe/gxp-regs.h | 208 +++++++++
 10 files changed, 1622 insertions(+)
 create mode 100644 drivers/soc/hpe/Kconfig
 create mode 100644 drivers/soc/hpe/Makefile
 create mode 100644 drivers/soc/hpe/gxp-csm.c
 create mode 100644 drivers/soc/hpe/gxp-fn2.c
 create mode 100644 drivers/soc/hpe/gxp-soclib.c
