 drivers/soc/Makefile             |   1 +
 drivers/soc/hpe/Kconfig          |  61 +++
 drivers/soc/hpe/Makefile         |   9 +
 drivers/soc/hpe/gxp-csm.c        | 266 +++++++++++
 drivers/soc/hpe/gxp-fn2.c        | 279 ++++++++++++
