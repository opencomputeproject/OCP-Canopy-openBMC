/dts-v1/;
/plugin/;
&{/} {
	model = "HPE ProLiant DL385 Gen11";
	compatible = "hpe,gxp-dl385gen11", "hpe,gxp";
};
&{/ahb@80000000} {
	cpu: cpu@800000b8 {
		compatible = "hpe,gxp-cpu", "simple-mfd", "syscon";
		reg = <0x800000b8 0x2>;
		#gpio-cells = <2>;
		gpio-line-names =
		"CPU1_PRSNT", "CPU2_PRSNT", "CPU3_PRSNT", "CPU4_PRSNT", "", "", "","",
		"", "", "", "", "", "", "", "";
	};
	i2cmux@0 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c0>;
		mux-controls = <&i2c_mux_ctrl 0>;
		#address-cells = <1>;
		#size-cells = <0>;
		i2c0@5 {
			reg = <5>;
			#address-cells = <1>;
			#size-cells = <0>;
			ddr5hub@50 {
				compatible = "jedec,spd5118";
				reg = <0x50>;
			};
			ddr5hub@51 {
				compatible = "jedec,spd5118";
				reg = <0x51>;
			};
			ddr5hub@52 {
				compatible = "jedec,spd5118";
				reg = <0x52>;
			};
			ddr5hub@53 {
				compatible = "jedec,spd5118";
				reg = <0x53>;
			};
			ddr5hub@54 {
				compatible = "jedec,spd5118";
				reg = <0x54>;
			};
			ddr5hub@55 {
				compatible = "jedec,spd5118";
				reg = <0x55>;
			};
		};
		i2c0@6 {
			reg = <6>;
			#address-cells = <1>;
			#size-cells = <0>;
			ddr5hub@50 {
				compatible = "jedec,spd5118";
				reg = <0x50>;
			};
			ddr5hub@51 {
				compatible = "jedec,spd5118";
				reg = <0x51>;
			};
			ddr5hub@52 {
				compatible = "jedec,spd5118";
				reg = <0x52>;
			};
			ddr5hub@53 {
				compatible = "jedec,spd5118";
				reg = <0x53>;
			};
			ddr5hub@54 {
				compatible = "jedec,spd5118";
				reg = <0x54>;
			};
			ddr5hub@55 {
				compatible = "jedec,spd5118";
				reg = <0x55>;
			};
		};
		i2c0@7 {
			reg = <7>;
			#address-cells = <1>;
			#size-cells = <0>;
			ddr5hub@50 {
				compatible = "jedec,spd5118";
				reg = <0x50>;
			};
			ddr5hub@51 {
				compatible = "jedec,spd5118";
				reg = <0x51>;
			};
			ddr5hub@52 {
				compatible = "jedec,spd5118";
				reg = <0x52>;
			};
			ddr5hub@53 {
				compatible = "jedec,spd5118";
				reg = <0x53>;
			};
			ddr5hub@54 {
				compatible = "jedec,spd5118";
				reg = <0x54>;
			};
			ddr5hub@55 {
				compatible = "jedec,spd5118";
				reg = <0x55>;
			};
		};
		i2c0@8 {
			reg = <8>;
			#address-cells = <1>;
			#size-cells = <0>;
			ddr5hub@50 {
				compatible = "jedec,spd5118";
				reg = <0x50>;
			};
			ddr5hub@51 {
				compatible = "jedec,spd5118";
				reg = <0x51>;
			};
			ddr5hub@52 {
				compatible = "jedec,spd5118";
				reg = <0x52>;
			};
			ddr5hub@53 {
				compatible = "jedec,spd5118";
				reg = <0x53>;
			};
			ddr5hub@54 {
				compatible = "jedec,spd5118";
				reg = <0x54>;
			};
			ddr5hub@55 {
				compatible = "jedec,spd5118";
				reg = <0x55>;
			};
		};
	};
	i2cmux@1 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c1>;
		mux-controls = <&i2c_mux_ctrl 1>;
		#address-cells = <1>;
		#size-cells = <0>;
		i2c1@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			cpu-monitor = <1>;
			sbrmi@3c {
				compatible = "amd,sbrmi";
				dimm-count = <12>;
				reg = <0x3c>;
				sbrmi-supply = <&i2c_passthrough>;
			};
			sbtsi@4c {
				compatible = "amd,sbtsi";
				reg = <0x4c>;
				sbtsi-supply = <&i2c_passthrough>;
			};
		};
		i2c1@2 {
			reg = <2>;
			#address-cells = <1>;
			#size-cells = <0>;
			cpu-monitor = <2>;
			sbrmi@38 {
				compatible = "amd,sbrmi";
				dimm-count = <12>;
				reg = <0x38>;
				sbrmi-supply = <&i2c_passthrough>;
			};
			sbtsi@48 {
				compatible = "amd,sbtsi";
				reg = <0x48>;
				sbtsi-supply = <&i2c_passthrough>;
			};
		};
	};
	i2cmux3: i2cmux@3 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c3>;
		mux-controls = <&i2c_mux_ctrl 3>;
		#address-cells = <1>;
		#size-cells = <0>;
		/* 5 7 9 b */
		i2c3_1: i2c3@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom1: piceeprom@1 {
				compatible = "atmel,24c02";
				label = "piceeprom1";
				reg = <0x57>;
			};
			ubm1: ubm@40 {
				compatible = "hpe,ubm4";
				eeprom_phandle = <&piceeprom1>;
				reg = <0x40>;
				#gpio-cells = <2>;
				gpio-line-names = "1_DRV1_PRESENCE", "1_DRV1_UUID", "1_DRV1_ACT",
				"1_DRV2_PRESENCE", "1_DRV2_UUID", "1_DRV2_ACT";
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
					drveeprom1@53 {
						compatible = "atmel,24c02";
						label = "drv1";
						reg = <0x53>;
					};
					thermsensor1@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv1>;
						reg = < 0x1b>;
					};
				};
				i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
					drveeprom2@53 {
						compatible = "atmel,24c02";
						label = "drv2";
						reg = <0x53>;
					};
					thermsensor2@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv2>;
						reg = < 0x1b>;
					};
				};
			};
		};
		i2c3_2: i2c3@2 {
			reg = <2>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom2: piceeprom@2 {
				compatible = "atmel,24c02";
				label = "piceeprom2";
				reg = <0x57>;
			};
			ubm2: ubm@40 {
