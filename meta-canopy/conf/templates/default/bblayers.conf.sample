# LAYER_CONF_VERSION is increased each time build/conf/bblayers.conf
# changes incompatibly
LCONF_VERSION = "8"

BBPATH = "${TOPDIR}"
BBFILES ?= ""

BBLAYERS ?= " \
  ##OEROOT##/meta-canopy \
  ##OEROOT##/openbmc/meta \
  ##OEROOT##/openbmc/meta-openembedded/meta-oe \
  ##OEROOT##/openbmc/meta-openembedded/meta-networking \
  ##OEROOT##/openbmc/meta-openembedded/meta-perl \
  ##OEROOT##/openbmc/meta-openembedded/meta-python \
  ##OEROOT##/openbmc/meta-openembedded/meta-webserver \
  ##OEROOT##/openbmc/meta-phosphor \
  ##OEROOT##/openbmc/meta-aspeed \
  "
